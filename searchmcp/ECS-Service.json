{
  "containerDefinitions": [
    {
      "name": "mcp-search",
      "image": "<<AWS ACCOUNT ID>>.dkr.ecr.<<AWS REGION>>.amazonaws.com/mcp-search:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "mcp",
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "MONGO_CREDS",
          "value": "<<YOUR SECRETS MANAGER PATH>>"
        },
        {
          "name": "MONGO_COL",
          "value": "listingsAndReviews"
        },    
        {
          "name": "MONGO_DB",
          "value": "sample_airbnb"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mcp-search",
          "mode": "non-blocking",
          "awslogs-create-group": "true",
          "max-buffer-size": "25m",
          "awslogs-region": "<<AWS REGION>>",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python health.py"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "systemControls": []
    }
  ],
  "family": "searchmcphost",
  "taskRoleArn": "arn:aws:iam::<<AWS ACCOUNT ID>>:role/ecsTaskExecutionRole",
  "executionRoleArn": "arn:aws:iam::<<AWS ACCOUNT ID>>:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "status": "ACTIVE",
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "3072",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "tags": []
}