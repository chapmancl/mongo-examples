# MongoDB MCP Server - Local Standalone Configuration
# Copy this file to .env.local and fill in your values

# ============================================================================
# REQUIRED: Mode Selection
# ============================================================================
# Set to 'true' to run in local mode without AWS dependencies
USE_LOCAL_MODE=true

# ============================================================================
# REQUIRED: Tool Configuration
# ============================================================================
# Name of the MCP tool to load from MongoDB configuration
# This must match a "Name" field in your mcp_config.mcp_tools collection
MCP_TOOL_NAME=AirbnbSearch

# ============================================================================
# REQUIRED: MongoDB Connection (Choose ONE option)
# ============================================================================

# Option 1: Full connection string (recommended)
MONGO_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/

# Option 2: Individual components
# MONGO_USERNAME=your_username
# MONGO_PASSWORD=your_password
# MONGO_URI=cluster.mongodb.net

# ============================================================================
# OPTIONAL: MongoDB Configuration Database
# ============================================================================
# Database and collection where MCP tool configurations are stored
MCP_CONFIG_DB=mcp_config
MCP_CONFIG_COL=mcp_tools

# ============================================================================
# OPTIONAL: AWS Configuration (for Bedrock LLM)
# ============================================================================
# AWS region for Bedrock service
AWS_REGION=us-east-2

# AWS credentials (if not using AWS CLI profile)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================================================
# OPTIONAL: LLM Model Configuration
# ============================================================================
# Bedrock LLM model to use
# LLM_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
# LLM_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
# LLM_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ============================================================================
# OPTIONAL: Server Configuration
# ============================================================================
# MongoDB connection timeout in milliseconds
MONGO_TIMEOUT=5000
TRANSPORT=http

# Server host and port (can also be set via command line arguments)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

